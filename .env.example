# ── Base de datos ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=toxinfo         # <-- Cambia al nombre de tu base de datos
DB_USER=postgre         # <-- Cambia a tu usuario de PostgreSQL
DB_PASSWORD=mi_password  # <-- Cambia a tu contraseña

# ── JWT ────────────────────────────────────────────
# Genera una clave segura con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=clave
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Rol por defecto para nuevos usuarios ───────────
# Consulta: SELECT id_rol, nombre_rol FROM rol;
DEFAULT_USER_ROL_ID=2

# ── Firebase Admin SDK ──────────────────────────────
# Opción A: Ruta al archivo JSON de cuenta de servicio
# FIREBASE_SERVICE_ACCOUNT_PATH=/ruta/a/serviceAccount.json
# Opción B: Contenido del JSON directo (escapado como una línea)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}
# Si no se define ninguna, Firebase Admin usará GOOGLE_APPLICATION_CREDENTIALS
